# ─────────────────────────────────────────
#  DIRECTORIES
# ─────────────────────────────────────────
USER_DIR := user
OBJ_DIR  := obj

# ─────────────────────────────────────────
#  TOOLS
# ─────────────────────────────────────────
CC      := i386-elf-gcc
LD      := i386-elf-ld
OBJCOPY := objcopy

# ─────────────────────────────────────────
#  FLAGS
# ─────────────────────────────────────────
CFLAGS  := -ffreestanding -m32 -O0 -Wall -Wextra -g3 -I$(USER_DIR)
LDFLAGS := -m elf_i386 -T user.ld

# ─────────────────────────────────────────
#  SOURCE DISCOVERY
# ─────────────────────────────────────────
SRCS := $(shell find $(USER_DIR) -name "*.c")
OBJS := $(patsubst $(USER_DIR)/%.c, $(OBJ_DIR)/%.o, $(SRCS))

# ─────────────────────────────────────────
#  OUTPUT
# ─────────────────────────────────────────
USER_ELF := $(OBJ_DIR)/user.elf
USER_BIN := $(OBJ_DIR)/user.bin

# ─────────────────────────────────────────
#  DEFAULT
# ─────────────────────────────────────────
all: $(USER_BIN)

# ─────────────────────────────────────────
#  COMPILE
# ─────────────────────────────────────────
$(OBJ_DIR)/%.o: $(USER_DIR)/%.c
	mkdir -p $(dir $@)
	$(CC) $(CFLAGS) -c $< -o $@

# ─────────────────────────────────────────
#  LINK
# ─────────────────────────────────────────
$(USER_ELF): $(OBJS)
	$(LD) $(LDFLAGS) -o $@ $^

# ─────────────────────────────────────────
#  ELF → FLAT BINARY
# ─────────────────────────────────────────
$(USER_BIN): $(USER_ELF)
	$(OBJCOPY) -O binary $< $@
	@echo "user binary: $(USER_BIN) $$(du -sh $(USER_BIN) | cut -f1)"

# ─────────────────────────────────────────
#  CLEAN
# ─────────────────────────────────────────
clean:
	rm -rf $(OBJ_DIR)

.PHONY: all clean